{
  "additionalProperties": false,
  "properties": {
    "claim_boundary": {
      "minLength": 1,
      "type": "string"
    },
    "content_projection": {
      "type": "object"
    },
    "generated_at": {
      "minLength": 1,
      "type": "string"
    },
    "managed_block": {
      "minLength": 1,
      "type": "string"
    },
    "managed_block_markers": {
      "additionalProperties": false,
      "properties": {
        "begin": {
          "const": "<!-- BEGIN MANAGED SKILLGUARD GLOBAL ROUTER -->",
