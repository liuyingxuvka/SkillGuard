        },
        "end": {
          "const": "<!-- END MANAGED SKILLGUARD GLOBAL ROUTER -->",
          "type": "string"
        }
      },
      "required": [
        "begin",
        "end"
      ],
      "type": "object"
    },
    "managed_block_content_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    },
    "projection_identity_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    },
    "registry_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    },
    "registry_path": {
      "type": "string"
    },
    "route_index": {
      "items": {
        "type": "object"
      },
      "type": "array"
    },
    "router_skill_id": {
      "const": "skillguard-global-router",
      "type": "string"
    },
    "schema_version": {
      "const": "skillguard.global_prompt_projection.current",
      "type": "string"
    }
    ,"template_content_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    },
    "template_lifecycle_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "generated_at",
    "router_skill_id",
    "registry_hash",
    "registry_path",
    "managed_block_markers",
    "managed_block",
    "content_projection",
    "template_content_hash",
    "managed_block_content_hash",
