{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "skillguard_test_mesh_manifest_current.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "mesh_id", "source_model_id", "profiles", "claim_boundary"],
  "properties": {
    "schema_version": {"const": "skillguard.test_mesh_manifest.current"},
    "mesh_id": {"type": "string", "minLength": 1},
    "source_model_id": {"type": "string", "minLength": 1},
    "profiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["profile_id", "closure_profile_id", "full_admission_required"],
        "properties": {
          "profile_id": {"type": "string", "minLength": 1},
          "closure_profile_id": {"type": "string", "minLength": 1},
          "full_admission_required": {"type": "boolean"}
        }
      }
    },
    "claim_boundary": {"type": "string", "minLength": 1}
  }
}
