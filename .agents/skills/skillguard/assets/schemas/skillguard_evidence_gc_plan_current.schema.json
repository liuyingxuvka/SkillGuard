{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "skillguard_evidence_gc_plan_current.schema.json",
  "title": "SkillGuard current read-only evidence collection plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "policy_id", "status", "owner_evidence_root", "inventory_snapshot_hash", "audit_hash", "inventory", "candidates", "candidate_byte_count", "findings", "claim_boundary", "plan_hash"],
  "properties": {
    "schema_version": {"const": "skillguard.evidence_gc_plan.current"},
    "policy_id": {"const": "skillguard.evidence_lifecycle.current"},
    "status": {"enum": ["ready", "blocked"]},
    "owner_evidence_root": {"$ref": "#/$defs/rootIdentity"},
    "inventory_snapshot_hash": {"$ref": "#/$defs/hash"},
    "audit_hash": {"$ref": "#/$defs/hash"},
    "inventory": {"type": "array", "items": {"$ref": "#/$defs/inventoryRow"}},
    "candidates": {"type": "array", "items": {"$ref": "#/$defs/candidate"}},
    "candidate_byte_count": {"type": "integer", "minimum": 0},
    "findings": {"type": "array", "items": {"$ref": "#/$defs/finding"}},
    "claim_boundary": {"type": "string", "minLength": 1},
    "plan_hash": {"$ref": "#/$defs/hash"}
  },
  "$defs": {
    "hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "relativePath": {"type": "string", "minLength": 1, "pattern": "^(?![/\\\\])(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"},
    "classification": {"enum": ["corrupt_or_ambiguous", "current", "active", "release_pinned", "installation_pinned", "failed_diagnostic", "historical_referenced", "quarantined_corrupt", "temporary", "orphan"]},
    "rootIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path_token", "identity_hash"],
      "properties": {
        "path_token": {"const": "owner_evidence_root"},
        "identity_hash": {"$ref": "#/$defs/hash"}
      }
    },
    "inventoryRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["relative_path", "byte_count", "content_hash", "classification"],
      "properties": {
        "relative_path": {"$ref": "#/$defs/relativePath"},
        "byte_count": {"type": "integer", "minimum": 0},
        "content_hash": {"$ref": "#/$defs/hash"},
        "classification": {"$ref": "#/$defs/classification"}
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["relative_path", "byte_count", "content_hash", "reason"],
      "properties": {
        "relative_path": {"$ref": "#/$defs/relativePath"},
        "byte_count": {"type": "integer", "minimum": 0},
        "content_hash": {"$ref": "#/$defs/hash"},
        "reason": {"const": "unreachable_from_declared_lifecycle_roots"}
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "severity", "relative_path", "detail"],
      "properties": {
        "code": {"type": "string", "minLength": 1},
        "severity": {"enum": ["blocker", "warning"]},
        "relative_path": {"type": "string"},
        "detail": {"type": "string"}
      }
    }
  }
}
