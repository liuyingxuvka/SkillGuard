{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skillguard.local/schemas/skillguard_portfolio_assembly_result_v1.schema.json",
  "title": "SkillGuard portfolio assembly result v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "preparation_id", "preparation_ref", "execution_ref",
    "status", "graduation_evidence_ref", "graduation_evidence_hash",
    "installed_parity_receipt",
    "production_revalidation_binding_refs", "production_revalidation_fingerprint",
    "full_run_receipt_id", "full_run_receipt_hash", "graduation_receipt_id",
    "graduation_receipt_hash", "completed_at", "claim_boundary", "result_hash"
  ],
  "properties": {
    "schema_version": {"const": "skillguard.portfolio_assembly_result.v1"},
    "preparation_id": {"type": "string", "minLength": 1},
    "preparation_ref": {"$ref": "#/$defs/ref"},
    "execution_ref": {"$ref": "#/$defs/ref"},
    "status": {"const": "assembled"},
    "graduation_evidence_ref": {"$ref": "#/$defs/ref"},
    "graduation_evidence_hash": {"$ref": "#/$defs/hash"},
    "installed_parity_receipt": {
      "oneOf": [
        {"type": "null"},
        {"$ref": "#/$defs/receipt_binding"}
      ]
    },
    "production_revalidation_binding_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/ref"}
    },
    "production_revalidation_fingerprint": {"$ref": "#/$defs/hash"},
    "full_run_receipt_id": {"type": "string", "minLength": 1},
    "full_run_receipt_hash": {"$ref": "#/$defs/hash"},
    "graduation_receipt_id": {"type": "string", "minLength": 1},
    "graduation_receipt_hash": {"$ref": "#/$defs/hash"},
    "completed_at": {"type": "string", "format": "date-time"},
    "claim_boundary": {"type": "string", "minLength": 1},
    "result_hash": {"$ref": "#/$defs/hash"}
  },
  "$defs": {
    "hash": {"type": "string", "pattern": "^[A-F0-9]{64}$"},
    "ref": {"type": "string", "pattern": "^record:[A-Za-z0-9._/-]+@[A-F0-9]{64}$"},
    "receipt_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref", "receipt_id", "receipt_hash"],
      "properties": {
        "ref": {"$ref": "#/$defs/ref"},
        "receipt_id": {"type": "string", "minLength": 1},
        "receipt_hash": {"$ref": "#/$defs/hash"}
      }
    }
  }
}
