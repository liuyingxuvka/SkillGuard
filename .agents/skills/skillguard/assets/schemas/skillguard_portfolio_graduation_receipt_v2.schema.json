{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skillguard.local/schemas/skillguard_portfolio_graduation_receipt_v2.schema.json",
  "title": "SkillGuard portfolio graduation receipt v2",
  "description": "Strict immutable parent receipt matching the current flattened full-run, target-scan, transaction, scope, and prior-proof projections.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "receipt_id",
    "registry_id",
    "scope_manifest_id",
    "scope_manifest_hash",
    "transaction_id",
    "base_registry_revision",
    "base_registry_hash",
    "registry_transaction",
    "skill_id",
    "target_kind",
    "skill_paths",
    "status",
    "guard_runtime",
    "contract_hash",
    "source_fingerprint",
    "target_identity",
    "target_identity_scan_receipt_id",
    "target_identity_scan_receipt_hash",
    "target_identity_scan_receipt_ref",
    "job_plan_refs",
    "job_plan_hash",
    "job_spec_refs",
    "job_spec_hash",
    "representative_jobs",
    "representative_job_ids",
    "evidence_record_refs",
    "production_revalidation_binding_refs",
    "production_revalidation_fingerprint",
    "full_run_receipt_id",
    "full_run_receipt_hash",
    "full_run_result_hash",
    "intended_entry_state_hash",
    "prior_evidence",
    "graduation_evidence_hash",
    "issued_at",
    "claim_boundary",
    "receipt_hash"
  ],
  "properties": {
    "schema_version": {"const": "skillguard.portfolio_graduation_receipt.v2"},
    "receipt_id": {"$ref": "#/$defs/non_empty_string"},
    "registry_id": {"$ref": "#/$defs/non_empty_string"},
    "scope_manifest_id": {"$ref": "#/$defs/non_empty_string"},
    "scope_manifest_hash": {"$ref": "#/$defs/hash"},
    "transaction_id": {"$ref": "#/$defs/non_empty_string"},
    "base_registry_revision": {"type": "integer", "minimum": 1},
    "base_registry_hash": {"$ref": "#/$defs/hash"},
    "registry_transaction": {"$ref": "#/$defs/registry_transaction"},
    "skill_id": {"$ref": "#/$defs/non_empty_string"},
    "target_kind": {"enum": ["single_skill", "skill_suite"]},
    "skill_paths": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/skill_path_token"}
    },
    "status": {"const": "current"},
    "guard_runtime": {"$ref": "#/$defs/guard"},
    "contract_hash": {"$ref": "#/$defs/hash"},
    "source_fingerprint": {"$ref": "#/$defs/hash"},
    "target_identity": {"$ref": "#/$defs/receipt_identity"},
    "target_identity_scan_receipt_id": {"$ref": "#/$defs/non_empty_string"},
    "target_identity_scan_receipt_hash": {"$ref": "#/$defs/hash"},
    "target_identity_scan_receipt_ref": {"$ref": "#/$defs/hash_bound_ref"},
    "job_plan_refs": {
      "type": "array",
      "minItems": 6,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/hash_bound_ref"}
    },
    "job_plan_hash": {"$ref": "#/$defs/hash"},
    "job_spec_refs": {
      "type": "array",
      "minItems": 6,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/hash_bound_ref"}
    },
    "job_spec_hash": {"$ref": "#/$defs/hash"},
    "representative_jobs": {"$ref": "#/$defs/required_representative_jobs"},
    "representative_job_ids": {
      "type": "array",
      "minItems": 6,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/non_empty_string"}
    },
    "evidence_record_refs": {
      "type": "array",
      "minItems": 6,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/hash_bound_ref"}
    },
    "production_revalidation_binding_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/hash_bound_ref"}
    },
    "production_revalidation_fingerprint": {"$ref": "#/$defs/hash"},
    "full_run_receipt_id": {"$ref": "#/$defs/non_empty_string"},
    "full_run_receipt_hash": {"$ref": "#/$defs/hash"},
    "full_run_result_hash": {"$ref": "#/$defs/hash"},
    "intended_entry_state_hash": {"$ref": "#/$defs/hash"},
    "prior_evidence": {
      "type": "array",
      "items": {"$ref": "#/$defs/prior_proof"}
    },
    "graduation_evidence_hash": {"$ref": "#/$defs/hash"},
    "issued_at": {"$ref": "#/$defs/timestamp"},
    "claim_boundary": {"$ref": "#/$defs/non_empty_string"},
    "receipt_hash": {"$ref": "#/$defs/hash"}
  },
  "allOf": [
    {
      "if": {
        "properties": {"target_kind": {"const": "single_skill"}},
        "required": ["target_kind"]
      },
      "then": {"properties": {"skill_paths": {"maxItems": 1}}}
    },
    {
      "if": {
        "properties": {"target_kind": {"const": "skill_suite"}},
        "required": ["target_kind"]
      },
      "then": {"properties": {"skill_paths": {"minItems": 2}}}
    }
  ],
  "$defs": {
    "non_empty_string": {"type": "string", "minLength": 1},
    "timestamp": {"type": "string", "format": "date-time"},
    "hash": {"type": "string", "pattern": "^[A-F0-9]{64}$"},
    "path_token": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]+(?:/[A-Za-z0-9._-]+)*$",
      "not": {"pattern": "(^|/)\\.\\.?($|/)"}
    },
    "skill_path_token": {
      "oneOf": [
        {"const": "."},
        {"$ref": "#/$defs/path_token"}
      ]
    },
    "hash_bound_ref": {
      "type": "string",
      "pattern": "^record:[A-Za-z0-9._/-]+@[A-F0-9]{64}$",
      "not": {"pattern": "record:(?:\\.\\.?/|.*/\\.\\.?/)"}
    },
    "guard": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtime_id", "file_count", "source_hash"],
      "properties": {
        "runtime_id": {"const": "skillguard-v2"},
        "file_count": {"type": "integer", "minimum": 1},
        "source_hash": {"$ref": "#/$defs/hash"}
      }
    },
    "job_class_id": {
      "enum": [
        "positive",
        "invalid_input",
        "recovery_or_resume",
        "out_of_scope",
        "native_check",
        "artifact_check",
        "judged_quality"
      ]
    },
    "one_job_class": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/job_class_id"}
    },
    "class_outcome": {
      "enum": [
        "closed",
        "expected_rejection_observed",
        "resume_replay_closed",
        "declined_without_mutation",
        "native_check_current",
        "artifact_current",
        "judged_quality_current"
      ]
    },
    "representative_job": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "job_id",
        "job_class_ids",
        "member_skill_id",
        "member_contract_hash",
        "job_spec_ref",
        "job_spec_hash",
        "covered_capability_ids",
        "evidence_refs",
        "expected_outcome",
        "observed_outcome"
      ],
      "properties": {
        "job_id": {"$ref": "#/$defs/non_empty_string"},
        "job_class_ids": {"$ref": "#/$defs/one_job_class"},
        "member_skill_id": {"$ref": "#/$defs/non_empty_string"},
        "member_contract_hash": {"$ref": "#/$defs/hash"},
        "job_spec_ref": {"$ref": "#/$defs/hash_bound_ref"},
        "job_spec_hash": {"$ref": "#/$defs/hash"},
        "covered_capability_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/non_empty_string"}
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/hash_bound_ref"}
        },
        "expected_outcome": {"$ref": "#/$defs/class_outcome"},
        "observed_outcome": {"$ref": "#/$defs/class_outcome"}
      },
      "allOf": [
        {"$ref": "#/$defs/job_positive"},
        {"$ref": "#/$defs/job_invalid_input"},
        {"$ref": "#/$defs/job_recovery"},
        {"$ref": "#/$defs/job_out_of_scope"},
        {"$ref": "#/$defs/job_native_check"},
        {"$ref": "#/$defs/job_artifact_check"},
        {"$ref": "#/$defs/job_judged_quality"}
      ]
    },
    "required_representative_jobs": {
      "type": "array",
      "minItems": 6,
      "items": {"$ref": "#/$defs/representative_job"},
      "allOf": [
        {"contains": {"properties": {"job_class_ids": {"contains": {"const": "positive"}}}}},
        {"contains": {"properties": {"job_class_ids": {"contains": {"const": "invalid_input"}}}}},
        {"contains": {"properties": {"job_class_ids": {"contains": {"const": "recovery_or_resume"}}}}},
        {"contains": {"properties": {"job_class_ids": {"contains": {"const": "out_of_scope"}}}}},
        {"contains": {"properties": {"job_class_ids": {"contains": {"const": "native_check"}}}}},
        {"contains": {"properties": {"job_class_ids": {"contains": {"const": "artifact_check"}}}}}
      ]
    },
    "receipt_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_kind",
        "skill_paths",
        "member_identities",
        "source_fingerprint",
        "contract_hash",
        "command_fingerprint",
        "environment_fingerprint",
        "coverage_fingerprint",
        "production_revalidation_fingerprint"
      ],
      "properties": {
        "target_kind": {"enum": ["single_skill", "skill_suite"]},
        "skill_paths": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/skill_path_token"}
        },
        "member_identities": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/member_identity"}
        },
        "source_fingerprint": {"$ref": "#/$defs/hash"},
        "contract_hash": {"$ref": "#/$defs/hash"},
        "command_fingerprint": {"$ref": "#/$defs/hash"},
        "environment_fingerprint": {"$ref": "#/$defs/hash"},
        "coverage_fingerprint": {"$ref": "#/$defs/hash"},
        "production_revalidation_fingerprint": {"$ref": "#/$defs/hash"}
      },
      "allOf": [
        {
          "if": {"properties": {"target_kind": {"const": "single_skill"}}},
          "then": {
            "properties": {
              "skill_paths": {"maxItems": 1},
              "member_identities": {"maxItems": 1}
            }
          }
        },
        {
          "if": {"properties": {"target_kind": {"const": "skill_suite"}}},
          "then": {
            "properties": {
              "skill_paths": {"minItems": 2},
              "member_identities": {"minItems": 2}
            }
          }
        }
      ]
    },
    "member_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "member_skill_id",
        "skill_path",
        "source_fingerprint",
        "contract_hash",
        "manifest_hash"
      ],
      "properties": {
        "member_skill_id": {"$ref": "#/$defs/non_empty_string"},
        "skill_path": {"$ref": "#/$defs/skill_path_token"},
        "source_fingerprint": {"$ref": "#/$defs/hash"},
        "contract_hash": {"$ref": "#/$defs/hash"},
        "manifest_hash": {"$ref": "#/$defs/hash"}
      }
    },
    "registry_transaction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "transaction_id",
        "base_registry_revision",
        "base_registry_hash",
        "committed_registry_revision",
        "intended_entry_state_hash"
      ],
      "properties": {
        "transaction_id": {"$ref": "#/$defs/non_empty_string"},
        "base_registry_revision": {"type": "integer", "minimum": 1},
        "base_registry_hash": {"$ref": "#/$defs/hash"},
        "committed_registry_revision": {"type": "integer", "minimum": 2},
        "intended_entry_state_hash": {"$ref": "#/$defs/hash"}
      }
    },
    "prior_proof": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "skill_id",
        "proof_kind",
        "proof_id",
        "proof_hash",
        "guard_runtime",
        "source_fingerprint",
        "contract_hash",
        "coverage_fingerprint"
      ],
      "properties": {
        "skill_id": {"$ref": "#/$defs/non_empty_string"},
        "proof_kind": {"enum": ["reuse_ticket", "full_run_receipt"]},
        "proof_id": {"$ref": "#/$defs/non_empty_string"},
        "proof_hash": {"$ref": "#/$defs/hash"},
        "guard_runtime": {"$ref": "#/$defs/guard"},
        "source_fingerprint": {"$ref": "#/$defs/hash"},
        "contract_hash": {"$ref": "#/$defs/hash"},
        "coverage_fingerprint": {"$ref": "#/$defs/hash"}
      }
    },
    "job_positive": {
      "if": {"properties": {"job_class_ids": {"contains": {"const": "positive"}}}},
      "then": {"properties": {"expected_outcome": {"const": "closed"}, "observed_outcome": {"const": "closed"}}}
    },
    "job_invalid_input": {
      "if": {"properties": {"job_class_ids": {"contains": {"const": "invalid_input"}}}},
      "then": {"properties": {"expected_outcome": {"const": "expected_rejection_observed"}, "observed_outcome": {"const": "expected_rejection_observed"}}}
    },
    "job_recovery": {
      "if": {"properties": {"job_class_ids": {"contains": {"const": "recovery_or_resume"}}}},
      "then": {"properties": {"expected_outcome": {"const": "resume_replay_closed"}, "observed_outcome": {"const": "resume_replay_closed"}}}
    },
    "job_out_of_scope": {
      "if": {"properties": {"job_class_ids": {"contains": {"const": "out_of_scope"}}}},
      "then": {"properties": {"expected_outcome": {"const": "declined_without_mutation"}, "observed_outcome": {"const": "declined_without_mutation"}}}
    },
    "job_native_check": {
      "if": {"properties": {"job_class_ids": {"contains": {"const": "native_check"}}}},
      "then": {"properties": {"expected_outcome": {"const": "native_check_current"}, "observed_outcome": {"const": "native_check_current"}}}
    },
    "job_artifact_check": {
      "if": {"properties": {"job_class_ids": {"contains": {"const": "artifact_check"}}}},
      "then": {"properties": {"expected_outcome": {"const": "artifact_current"}, "observed_outcome": {"const": "artifact_current"}}}
    },
    "job_judged_quality": {
      "if": {"properties": {"job_class_ids": {"contains": {"const": "judged_quality"}}}},
      "then": {"properties": {"expected_outcome": {"const": "judged_quality_current"}, "observed_outcome": {"const": "judged_quality_current"}}}
    }
  }
}
