      "if": {"properties": {"job_class_ids": {"contains": {"const": "invalid_input"}}}},
      "then": {"properties": {"expected_outcome": {"const": "expected_rejection_observed"}, "observed_outcome": {"const": "expected_rejection_observed"}}}
    },
