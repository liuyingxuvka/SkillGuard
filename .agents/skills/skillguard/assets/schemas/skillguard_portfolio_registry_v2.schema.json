        },
        "member_revalidation_statuses": {
          "$ref": "#/$defs/member_revalidation_statuses"
        },
        "required_job_class_ids": {"$ref": "#/$defs/required_job_classes"},
        "contract_hash": {"$ref": "#/$defs/hash_or_empty"},
        "representative_jobs": {"$ref": "#/$defs/representative_jobs"},
        "representative_job_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/non_empty_string"}
        },
        "full_run_receipt": {
          "oneOf": [{"type": "null"}, {"$ref": "#/$defs/full_run_receipt"}]
        },
        "production_revalidation_bindings": {
          "type": "array",
          "items": {"$ref": "#/$defs/production_revalidation_binding"}
