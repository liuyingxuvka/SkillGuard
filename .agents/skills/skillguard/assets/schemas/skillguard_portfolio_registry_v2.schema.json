{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skillguard.local/schemas/skillguard_portfolio_registry_v2.schema.json",
  "title": "SkillGuard portfolio registry v2",
  "description": "Strict schema for the one current private SkillGuard portfolio registry, including reviewed-scope binding, enriched lifecycle entries, mutation history, and Guard history.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "registry_id",
    "scope_manifest_id",
    "scope_manifest_hash",
    "scope_manifest_ref",
    "revision",
    "previous_registry_hash",
    "active_guard",
    "entries",
    "transaction_history",
    "created_at",
    "updated_at",
    "registry_hash"
  ],
  "properties": {
    "schema_version": {"const": "skillguard.portfolio_registry.v2"},
    "registry_id": {"$ref": "#/$defs/non_empty_string"},
    "scope_manifest_id": {"$ref": "#/$defs/non_empty_string"},
    "scope_manifest_hash": {"$ref": "#/$defs/hash"},
    "scope_manifest_ref": {"$ref": "#/$defs/hash_bound_ref"},
    "revision": {"type": "integer", "minimum": 1},
    "previous_registry_hash": {
      "oneOf": [{"const": ""}, {"$ref": "#/$defs/hash"}]
    },
    "active_guard": {"$ref": "#/$defs/guard"},
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {"$ref": "#/$defs/active_entry"},
          {"$ref": "#/$defs/excluded_entry"},
          {"$ref": "#/$defs/supporting_entry"}
        ]
      }
    },
    "transaction_history": {
      "type": "array",
      "items": {"$ref": "#/$defs/registry_transaction"}
    },
    "guard_change_history": {
      "type": "array",
      "items": {"$ref": "#/$defs/guard_change_history_entry"}
    },
    "created_at": {"$ref": "#/$defs/timestamp"},
    "updated_at": {"$ref": "#/$defs/timestamp"},
    "registry_hash": {"$ref": "#/$defs/hash"}
  },
  "allOf": [
    {
      "if": {
        "properties": {"revision": {"minimum": 2}},
        "required": ["revision"]
      },
      "then": {
        "properties": {
          "previous_registry_hash": {"$ref": "#/$defs/hash"},
          "transaction_history": {"minItems": 1}
        }
      }
    }
  ],
  "$defs": {
    "non_empty_string": {"type": "string", "minLength": 1},
    "timestamp": {"type": "string", "format": "date-time"},
    "hash": {"type": "string", "pattern": "^[A-F0-9]{64}$"},
    "path_token": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]+(?:/[A-Za-z0-9._-]+)*$",
      "not": {"pattern": "(^|/)\\.\\.?($|/)"}
    },
    "skill_path_token": {
      "oneOf": [
        {"const": "."},
        {"$ref": "#/$defs/path_token"}
      ]
    },
    "hash_or_empty": {"type": "string", "pattern": "^(?:[A-F0-9]{64})?$"},
    "timestamp_or_empty": {
      "oneOf": [{"const": ""}, {"$ref": "#/$defs/timestamp"}]
    },
    "hash_bound_ref": {
      "type": "string",
      "pattern": "^record:[A-Za-z0-9._/-]+@[A-F0-9]{64}$",
      "not": {"pattern": "record:(?:\\.\\.?/|.*/\\.\\.?/)"}
    },
    "guard": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtime_id", "file_count", "source_hash"],
      "properties": {
        "runtime_id": {"const": "skillguard-v2"},
        "provider_id": {"$ref": "#/$defs/non_empty_string"},
        "runtime_contract_id": {"$ref": "#/$defs/non_empty_string"},
        "capability_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/non_empty_string"}
        },
        "enrollment_status": {"const": "enrolled"},
        "file_count": {"type": "integer", "minimum": 1},
        "source_hash": {"$ref": "#/$defs/hash"},
        "portfolio_projection_hash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      }
    },
    "job_class_id": {
      "enum": [
        "positive",
        "invalid_input",
        "recovery_or_resume",
        "out_of_scope",
        "native_check",
        "artifact_check",
        "judged_quality"
      ]
    },
    "required_job_classes": {
      "type": "array",
      "minItems": 6,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/job_class_id"},
      "allOf": [
        {"contains": {"const": "positive"}},
        {"contains": {"const": "invalid_input"}},
        {"contains": {"const": "recovery_or_resume"}},
        {"contains": {"const": "out_of_scope"}},
        {"contains": {"const": "native_check"}},
        {"contains": {"const": "artifact_check"}}
      ]
    },
    "one_job_class": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/job_class_id"}
    },
    "class_outcome": {
      "enum": [
        "closed",
        "expected_rejection_observed",
        "resume_replay_closed",
        "declined_without_mutation",
        "native_check_current",
        "artifact_current",
        "judged_quality_current"
      ]
    },
    "representative_job": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "job_id",
        "job_class_ids",
        "member_skill_id",
        "member_contract_hash",
        "job_spec_ref",
        "job_spec_hash",
        "covered_capability_ids",
        "evidence_refs",
        "expected_outcome",
        "observed_outcome"
      ],
      "properties": {
        "job_id": {"$ref": "#/$defs/non_empty_string"},
        "job_class_ids": {"$ref": "#/$defs/one_job_class"},
        "member_skill_id": {"$ref": "#/$defs/non_empty_string"},
        "member_contract_hash": {"$ref": "#/$defs/hash"},
        "job_spec_ref": {"$ref": "#/$defs/hash_bound_ref"},
        "job_spec_hash": {"$ref": "#/$defs/hash"},
        "covered_capability_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/non_empty_string"}
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/hash_bound_ref"}
        },
        "expected_outcome": {"$ref": "#/$defs/class_outcome"},
        "observed_outcome": {"$ref": "#/$defs/class_outcome"}
      },
      "allOf": [
        {"$ref": "#/$defs/job_positive"},
        {"$ref": "#/$defs/job_invalid_input"},
        {"$ref": "#/$defs/job_recovery"},
        {"$ref": "#/$defs/job_out_of_scope"},
        {"$ref": "#/$defs/job_native_check"},
        {"$ref": "#/$defs/job_artifact_check"},
        {"$ref": "#/$defs/job_judged_quality"}
      ]
    },
    "representative_jobs": {
      "type": "array",
      "items": {"$ref": "#/$defs/representative_job"}
    },
    "required_representative_jobs": {
      "type": "array",
      "minItems": 6,
      "items": {"$ref": "#/$defs/representative_job"},
      "allOf": [
        {"contains": {"properties": {"job_class_ids": {"contains": {"const": "positive"}}}}},
        {"contains": {"properties": {"job_class_ids": {"contains": {"const": "invalid_input"}}}}},
        {"contains": {"properties": {"job_class_ids": {"contains": {"const": "recovery_or_resume"}}}}},
        {"contains": {"properties": {"job_class_ids": {"contains": {"const": "out_of_scope"}}}}},
        {"contains": {"properties": {"job_class_ids": {"contains": {"const": "native_check"}}}}},
        {"contains": {"properties": {"job_class_ids": {"contains": {"const": "artifact_check"}}}}}
      ]
    },
    "repository_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["host", "owner", "name", "visibility"],
      "properties": {
        "host": {"$ref": "#/$defs/non_empty_string"},
        "owner": {"$ref": "#/$defs/non_empty_string"},
        "name": {"$ref": "#/$defs/non_empty_string"},
        "visibility": {"$ref": "#/$defs/non_empty_string"}
      }
    },
    "canonical_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path_token", "skill_path", "version", "source_fingerprint"],
      "properties": {
        "path_token": {"$ref": "#/$defs/path_token"},
        "skill_path": {"$ref": "#/$defs/skill_path_token"},
        "version": {"type": "string"},
        "source_fingerprint": {"$ref": "#/$defs/hash"},
        "repository_identity": {"$ref": "#/$defs/repository_identity"}
      }
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["origin", "visibility"],
      "properties": {
        "origin": {"$ref": "#/$defs/non_empty_string"},
        "visibility": {"$ref": "#/$defs/non_empty_string"}
      }
    },
    "member_capability_inventory": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "member_skill_id",
          "skill_path",
          "required_capability_ids"
        ],
        "properties": {
          "member_skill_id": {"$ref": "#/$defs/non_empty_string"},
          "skill_path": {"$ref": "#/$defs/skill_path_token"},
          "required_capability_ids": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"$ref": "#/$defs/non_empty_string"}
          }
        }
      }
    },
    "member_revalidation_statuses": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "graduation_status",
          "pending_guard_change_id",
          "reuse_ticket_absent"
        ],
        "properties": {
          "graduation_status": {"const": "revalidation_required"},
          "pending_guard_change_id": {"$ref": "#/$defs/non_empty_string"},
          "reuse_ticket_absent": {"const": true}
        }
      }
    },
    "target_identity_receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "skill_id",
        "skill_root_token",
        "target_kind",
        "skill_paths",
        "member_identities",
        "source_fingerprint",
        "contract_hash",
        "manifest_hash",
        "guard_runtime",
        "version",
        "issued_by",
        "claim_boundary",
        "receipt_id",
        "receipt_hash"
      ],
      "properties": {
        "schema_version": {"const": "skillguard.target_identity_scan_receipt.v1"},
        "skill_id": {"$ref": "#/$defs/non_empty_string"},
        "skill_root_token": {"$ref": "#/$defs/skill_path_token"},
        "target_kind": {"enum": ["single_skill", "skill_suite"]},
        "skill_paths": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/skill_path_token"}
        },
        "member_identities": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/member_identity"}
        },
        "source_fingerprint": {"$ref": "#/$defs/hash"},
        "contract_hash": {"$ref": "#/$defs/hash"},
        "manifest_hash": {"$ref": "#/$defs/hash"},
        "guard_runtime": {"$ref": "#/$defs/guard"},
        "version": {"type": "string"},
        "issued_by": {"$ref": "#/$defs/non_empty_string"},
        "claim_boundary": {"$ref": "#/$defs/non_empty_string"},
        "receipt_id": {"$ref": "#/$defs/non_empty_string"},
        "receipt_hash": {"$ref": "#/$defs/hash"}
      },
      "allOf": [
        {
          "if": {"properties": {"target_kind": {"const": "single_skill"}}},
          "then": {
            "properties": {
              "skill_paths": {"maxItems": 1},
              "member_identities": {"maxItems": 1}
            }
          }
        },
        {
          "if": {"properties": {"target_kind": {"const": "skill_suite"}}},
          "then": {
            "properties": {
              "skill_paths": {"minItems": 2},
              "member_identities": {"minItems": 2}
            }
          }
        }
      ]
    },
    "member_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "member_skill_id",
        "skill_path",
        "source_fingerprint",
        "contract_hash",
        "manifest_hash"
      ],
      "properties": {
        "member_skill_id": {"$ref": "#/$defs/non_empty_string"},
        "skill_path": {"$ref": "#/$defs/skill_path_token"},
        "source_fingerprint": {"$ref": "#/$defs/hash"},
        "contract_hash": {"$ref": "#/$defs/hash"},
        "manifest_hash": {"$ref": "#/$defs/hash"}
      }
    },
    "execution_environment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "os_name",
        "platform",
        "python_implementation",
        "python_version"
      ],
      "properties": {
        "os_name": {"$ref": "#/$defs/non_empty_string"},
        "platform": {"$ref": "#/$defs/non_empty_string"},
        "python_implementation": {"$ref": "#/$defs/non_empty_string"},
        "python_version": {"$ref": "#/$defs/non_empty_string"}
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "check_record_id",
        "check_record_hash",
        "command",
        "args",
        "cwd_token",
        "cwd_relative",
        "exit_code",
        "expected_exit_code",
        "stdout_content_hash",
        "stderr_content_hash",
        "execution_environment_fingerprint"
      ],
      "properties": {
        "check_record_id": {"$ref": "#/$defs/non_empty_string"},
        "check_record_hash": {"$ref": "#/$defs/hash"},
        "command": {"$ref": "#/$defs/non_empty_string"},
        "args": {"type": "array", "items": {"type": "string"}},
        "cwd_token": {"$ref": "#/$defs/non_empty_string"},
        "cwd_relative": {"type": "string"},
        "exit_code": {"type": "integer"},
        "expected_exit_code": {"type": "integer"},
        "stdout_content_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "stderr_content_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "execution_environment_fingerprint": {"$ref": "#/$defs/hash"}
      }
    },
    "command_job": {
      "type": "object",
      "additionalProperties": false,
      "required": ["job_id", "executions"],
      "properties": {
        "job_id": {"$ref": "#/$defs/non_empty_string"},
        "executions": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/execution"}
        }
      }
    },
    "command_set": {
      "type": "object",
      "additionalProperties": false,
      "required": ["jobs"],
      "properties": {
        "jobs": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/command_job"}
        }
      }
    },
    "environment_execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "job_id",
        "check_record_id",
        "environment",
        "environment_fingerprint"
      ],
      "properties": {
        "job_id": {"$ref": "#/$defs/non_empty_string"},
        "check_record_id": {"$ref": "#/$defs/non_empty_string"},
        "environment": {"$ref": "#/$defs/execution_environment"},
        "environment_fingerprint": {"$ref": "#/$defs/hash"}
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["executions"],
      "properties": {
        "executions": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/environment_execution"}
        }
      }
    },
    "class_outcome": {
      "enum": [
        "closed",
        "expected_rejection_observed",
        "resume_replay_closed",
        "declined_without_mutation",
        "native_check_current",
        "artifact_current",
        "judged_quality_current"
      ]
    },
    "job_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "job_id",
        "job_class_ids",
        "member_skill_id",
        "member_contract_hash",
        "covered_capability_ids",
        "evidence_refs",
        "outcome",
        "status"
      ],
      "properties": {
        "job_id": {"$ref": "#/$defs/non_empty_string"},
        "job_class_ids": {"$ref": "#/$defs/one_job_class"},
        "member_skill_id": {"$ref": "#/$defs/non_empty_string"},
        "member_contract_hash": {"$ref": "#/$defs/hash"},
        "covered_capability_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/non_empty_string"}
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/hash_bound_ref"}
        },
        "outcome": {"$ref": "#/$defs/class_outcome"},
        "status": {"const": "verified"}
      }
    },
    "result_bundle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["representative_job_results"],
      "properties": {
        "representative_job_results": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/job_result"}
        }
      }
    },
    "full_run_receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_id",
        "status",
        "guard_runtime",
        "source_fingerprint",
        "contract_hash",
        "command_set",
        "command_fingerprint",
        "environment",
        "environment_fingerprint",
        "coverage_fingerprint",
        "production_revalidation_bindings",
        "production_revalidation_fingerprint",
        "result_bundle",
        "result_hash",
        "completed_at",
        "claim_boundary",
        "receipt_hash"
      ],
      "properties": {
        "receipt_id": {"$ref": "#/$defs/non_empty_string"},
        "status": {"const": "current"},
        "guard_runtime": {"$ref": "#/$defs/guard"},
        "source_fingerprint": {"$ref": "#/$defs/hash"},
        "contract_hash": {"$ref": "#/$defs/hash"},
        "command_set": {"$ref": "#/$defs/command_set"},
        "command_fingerprint": {"$ref": "#/$defs/hash"},
        "environment": {"$ref": "#/$defs/environment"},
        "environment_fingerprint": {"$ref": "#/$defs/hash"},
        "coverage_fingerprint": {"$ref": "#/$defs/hash"},
        "production_revalidation_bindings": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/production_revalidation_binding"}
        },
        "production_revalidation_fingerprint": {"$ref": "#/$defs/hash"},
        "result_bundle": {"$ref": "#/$defs/result_bundle"},
        "result_hash": {"$ref": "#/$defs/hash"},
        "completed_at": {"$ref": "#/$defs/timestamp"},
        "claim_boundary": {"$ref": "#/$defs/non_empty_string"},
        "receipt_hash": {"$ref": "#/$defs/hash"}
      }
    },
    "receipt_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_fingerprint",
        "contract_hash",
        "command_fingerprint",
        "environment_fingerprint",
        "coverage_fingerprint"
      ],
      "properties": {
        "source_fingerprint": {"$ref": "#/$defs/hash"},
        "contract_hash": {"$ref": "#/$defs/hash"},
        "command_fingerprint": {"$ref": "#/$defs/hash"},
        "environment_fingerprint": {"$ref": "#/$defs/hash"},
        "coverage_fingerprint": {"$ref": "#/$defs/hash"}
      }
    },
    "production_revalidation_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["member_skill_id", "binding_ref", "binding_hash"],
      "properties": {
        "member_skill_id": {"$ref": "#/$defs/non_empty_string"},
        "binding_ref": {"$ref": "#/$defs/hash_bound_ref"},
        "binding_hash": {"$ref": "#/$defs/hash"}
      }
    },
    "target_identity_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_kind",
        "skill_paths",
        "member_identities",
        "source_fingerprint",
        "contract_hash",
        "command_fingerprint",
        "environment_fingerprint",
        "coverage_fingerprint",
        "production_revalidation_fingerprint"
      ],
      "properties": {
        "target_kind": {"enum": ["single_skill", "skill_suite"]},
        "skill_paths": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/skill_path_token"}
        },
        "member_identities": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/member_identity"}
        },
        "source_fingerprint": {"$ref": "#/$defs/hash"},
        "contract_hash": {"$ref": "#/$defs/hash"},
        "command_fingerprint": {"$ref": "#/$defs/hash"},
        "environment_fingerprint": {"$ref": "#/$defs/hash"},
        "coverage_fingerprint": {"$ref": "#/$defs/hash"},
        "production_revalidation_fingerprint": {"$ref": "#/$defs/hash"}
      },
      "allOf": [
        {
          "if": {"properties": {"target_kind": {"const": "single_skill"}}},
          "then": {"properties": {"skill_paths": {"maxItems": 1}, "member_identities": {"maxItems": 1}}}
        },
        {
          "if": {"properties": {"target_kind": {"const": "skill_suite"}}},
          "then": {"properties": {"skill_paths": {"minItems": 2}, "member_identities": {"minItems": 2}}}
        }
      ]
    },
    "reuse_ticket": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "ticket_id",
        "transaction_id",
        "skill_id",
        "status",
        "change_id",
        "from_guard",
        "to_guard",
        "affected_feature_tags",
        "broad_semantic_change",
        "identity",
        "registry_id",
        "scope_manifest_id",
        "scope_manifest_hash",
        "base_registry_revision",
        "base_registry_hash",
        "previous_full_receipt_hash",
        "target_identity_receipt_id",
        "target_identity_receipt_hash",
        "issued_at",
        "claim_boundary",
        "ticket_hash"
      ],
      "properties": {
        "schema_version": {"const": "skillguard.test_result_reuse_ticket.v2"},
        "ticket_id": {"$ref": "#/$defs/non_empty_string"},
        "transaction_id": {"$ref": "#/$defs/non_empty_string"},
        "skill_id": {"$ref": "#/$defs/non_empty_string"},
        "status": {"const": "current"},
        "change_id": {"$ref": "#/$defs/non_empty_string"},
        "from_guard": {"$ref": "#/$defs/guard"},
        "to_guard": {"$ref": "#/$defs/guard"},
        "affected_feature_tags": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/non_empty_string"}
        },
        "broad_semantic_change": {"const": false},
        "identity": {"$ref": "#/$defs/receipt_identity"},
