              "target_identity_receipt": {"$ref": "#/$defs/target_identity_receipt"},
              "portfolio_graduation_receipt": {"$ref": "#/$defs/portfolio_graduation_receipt"},
              "last_revalidation": {"$ref": "#/$defs/timestamp"},
              "failure_classification": {"type": "null"},
              "unresolved_failure_ids": {"maxItems": 0}
            }
          }
        },
        {
          "if": {
            "properties": {"reuse_ticket": {"type": "object"}},
            "required": ["reuse_ticket"]
          },
          "then": {"properties": {"reuse_ticket_chain": {"minItems": 1}}}
        }
      ]
