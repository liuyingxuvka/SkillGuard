          "if": {"properties": {"target_kind": {"const": "skill_suite"}}},
          "then": {"properties": {"skill_paths": {"minItems": 2}}}
        },
        {
          "if": {
            "properties": {"graduation_status": {"const": "current"}},
            "required": ["graduation_status"]
          },
          "then": {
            "not": {"required": ["member_revalidation_statuses"]},
            "required": [
              "contract_hash",
              "representative_jobs",
              "representative_job_ids",
              "full_run_receipt",
              "production_revalidation_bindings",
              "production_revalidation_fingerprint",
              "target_identity_receipt",
              "portfolio_graduation_receipt",
              "last_revalidation",
              "failure_classification"
            ],
            "properties": {
              "capability_inventory_status": {"const": "current"},
              "required_capability_ids": {"minItems": 1},
              "contract_hash": {"$ref": "#/$defs/hash"},
              "representative_jobs": {"$ref": "#/$defs/required_representative_jobs"},
              "representative_job_ids": {"minItems": 6},
              "full_run_receipt": {"$ref": "#/$defs/full_run_receipt"},
              "production_revalidation_bindings": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/production_revalidation_binding"}},
