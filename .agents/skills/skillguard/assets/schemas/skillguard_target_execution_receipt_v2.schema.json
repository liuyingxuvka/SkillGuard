{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/liuyingxuvka/SkillGuard/schemas/skillguard_target_execution_receipt_v2.schema.json",
  "title": "SkillGuard target-declared check execution receipt v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "receipt_id", "sequence", "receipt_hash", "run_id",
    "target_skill_id", "contract_hash", "profile_id", "profile_fingerprint",
    "integration_mode", "native_owner_id", "native_route_ids", "native_check_ids",
    "request_fingerprint", "declared_check_inventory", "declared_check_results",
    "unresolved_check_ids", "evidence_domain", "scheduled_production_identity",
    "status", "enforcement_decision", "dimension_results", "coverage_universe_results",
    "obligation_results", "evidence_contributions", "provider_runtime_audit",
    "observation_binding", "root_role_bindings", "root_role_bindings_hash",
    "uncovered_obligation_ids", "blockers", "input_fingerprints",
    "input_fingerprint_hash", "target_fingerprint", "runtime_fingerprint",
    "active_runtime_identity", "active_runtime_identity_hash", "evaluation_hash",
    "supersedes_receipt_id", "claim_boundary", "created_at"
  ],
  "properties": {
    "schema_version": {"const": "skillguard.target_execution_receipt.v2"},
    "receipt_id": {"$ref": "#/$defs/text"},
    "sequence": {"type": "integer", "minimum": 1},
    "receipt_hash": {"$ref": "#/$defs/hash"},
    "run_id": {"$ref": "#/$defs/text"},
    "target_skill_id": {"$ref": "#/$defs/text"},
    "contract_hash": {"$ref": "#/$defs/hash"},
    "profile_id": {"$ref": "#/$defs/text"},
    "profile_fingerprint": {"$ref": "#/$defs/hash"},
    "integration_mode": {"const": "native-integrated"},
    "native_owner_id": {"$ref": "#/$defs/text"},
    "native_route_ids": {"$ref": "#/$defs/ids"},
    "native_check_ids": {"$ref": "#/$defs/nonempty_ids"},
    "request_fingerprint": {"$ref": "#/$defs/hash"},
    "declared_check_inventory": {"type": "object"},
    "declared_check_results": {"type": "array", "items": {"type": "object"}},
    "unresolved_check_ids": {"$ref": "#/$defs/ids"},
    "evidence_domain": {"enum": ["fixture_validation", "capability_validation", "scheduled_production"]},
    "scheduled_production_identity": {"type": "object"},
    "status": {"type": "string"},
    "enforcement_decision": {"enum": ["allow", "block"]},
    "dimension_results": {"type": "array"},
    "coverage_universe_results": {"type": "array"},
    "obligation_results": {"type": "array"},
    "evidence_contributions": {"type": "array"},
    "provider_runtime_audit": {"type": "object"},
    "observation_binding": {"type": "object"},
    "root_role_bindings": {"type": "object"},
    "root_role_bindings_hash": {"$ref": "#/$defs/hash"},
    "uncovered_obligation_ids": {"$ref": "#/$defs/ids"},
    "blockers": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
    "input_fingerprints": {"type": "object"},
    "input_fingerprint_hash": {"$ref": "#/$defs/hash"},
    "target_fingerprint": {"$ref": "#/$defs/hash"},
    "runtime_fingerprint": {"$ref": "#/$defs/hash"},
    "active_runtime_identity": {"type": "object"},
    "active_runtime_identity_hash": {"$ref": "#/$defs/hash"},
    "evaluation_hash": {"$ref": "#/$defs/hash"},
    "supersedes_receipt_id": {"type": "string"},
    "claim_boundary": {"$ref": "#/$defs/text"},
    "created_at": {"type": "string", "format": "date-time"}
  },
  "$defs": {
    "text": {"type": "string", "minLength": 1},
    "hash": {"type": "string", "pattern": "^[A-F0-9]{64}$"},
    "ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "nonempty_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
  }
}
