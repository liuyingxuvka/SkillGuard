{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "SkillGuard runnable work-contract schema for one target skill.",
  "properties": {
    "check_scripts": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "check_id": {
            "minLength": 1,
            "type": "string"
          },
          "command": {
            "minLength": 1,
            "type": "string"
          },
          "failure_class": {
            "minLength": 1,
            "type": "string"
          },
          "phase_id": {
            "minLength": 1,
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "script_path": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "check_id",
          "phase_id",
          "script_path",
          "command",
          "required",
          "failure_class"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "claim_boundary": {
      "minLength": 1,
      "type": "string"
    },
    "closure_rules": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "allowed_decision": {
            "enum": [
              "checked",
              "accepted",
              "needs-review",
              "blocked",
              "failed",
              "stale"
            ],
            "type": "string"
          },
          "required_checks": {
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "type": "array"
          },
          "required_evidence": {
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "type": "array"
          },
          "rule_id": {
            "minLength": 1,
            "type": "string"
          },
          "scope": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "rule_id",
          "scope",
          "allowed_decision",
          "required_checks",
          "required_evidence"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "closure_blockers": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "blocker_id": {
            "minLength": 1,
            "type": "string"
          },
          "blocks_decisions": {
            "items": {
              "enum": [
                "checked",
                "accepted",
                "needs-review",
                "blocked",
                "failed",
                "stale"
              ],
              "type": "string"
            },
            "minItems": 1,
            "type": "array"
          },
          "failure_class": {
            "minLength": 1,
            "type": "string"
          },
          "obligation_ids": {
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "minItems": 1,
            "type": "array"
          },
          "summary": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "blocker_id",
          "obligation_ids",
          "failure_class",
          "blocks_decisions",
          "summary"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "contract_hash": {
      "minLength": 1,
      "type": "string"
    },
    "contract_version": {
      "minLength": 1,
      "type": "string"
    },
    "integration_claim_boundary": {
      "minLength": 1,
      "type": "string"
    },
    "integration_mode": {
      "enum": [
        "native-integrated",
        "hybrid-extension",
        "skillguard-runtime"
      ],
      "type": "string"
    },
    "acceptance_obligations": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "covered_by_checks": {
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "type": "array"
          },
          "native_check_binding_ids": {
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "type": "array"
          },
          "obligation_id": {
            "minLength": 1,
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "requirement_ids": {
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "minItems": 1,
            "type": "array"
          },
          "summary": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "obligation_id",
          "requirement_ids",
          "summary",
          "required",
          "covered_by_checks",
          "native_check_binding_ids"
