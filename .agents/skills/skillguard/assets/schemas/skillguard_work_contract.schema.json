        "type": "object"
      },
      "type": "array"
    },
    "cleanup_required": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "cleanup_id": {
            "minLength": 1,
            "type": "string"
          },
          "paths": {
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "type": "array"
          },
          "required": {
            "type": "boolean"
          },
          "status": {
            "enum": [
              "not-needed",
              "required",
              "complete",
              "blocked"
            ],
            "type": "string"
          },
          "summary": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "cleanup_id",
          "summary",
          "paths",
          "required",
          "status"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "may_define_parallel_execution_route": {
      "type": "boolean"
    },
    "may_define_skillguard_runtime_route": {
      "type": "boolean"
    },
    "native_check_bindings": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "binding_id": {
            "minLength": 1,
            "type": "string"
          },
          "command": {
            "minLength": 1,
            "type": "string"
          },
          "evidence_source": {
            "minLength": 1,
            "type": "string"
          },
          "native_check_id": {
            "minLength": 1,
            "type": "string"
          },
          "required": {
            "type": "boolean"
          }
        },
        "required": [
          "binding_id",
          "native_check_id",
          "evidence_source",
          "required"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "phase_native_bindings": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "evidence_source": {
            "minLength": 1,
            "type": "string"
          },
          "native_check_binding_ids": {
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "minItems": 1,
            "type": "array"
          },
          "native_route_binding_id": {
            "minLength": 1,
            "type": "string"
          },
          "phase_id": {
            "minLength": 1,
            "type": "string"
          },
          "required": {
            "type": "boolean"
          }
        },
        "required": [
          "phase_id",
          "native_route_binding_id",
          "native_check_binding_ids",
          "evidence_source",
          "required"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "native_route_bindings": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "binding_id": {
            "minLength": 1,
            "type": "string"
          },
          "native_route_id": {
            "minLength": 1,
            "type": "string"
          },
          "required_before_closure": {
            "type": "boolean"
          },
          "source": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "binding_id",
          "native_route_id",
          "source",
          "required_before_closure"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "not_parallel_route_proof": {
      "additionalProperties": false,
      "properties": {
        "evidence_source": {
          "minLength": 1,
          "type": "string"
        },
        "native_route_binding_ids": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "proof_id": {
          "minLength": 1,
          "type": "string"
        },
        "summary": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "proof_id",
        "summary",
        "native_route_binding_ids",
        "evidence_source"
      ],
      "type": "object"
    },
    "native_route_owner": {
      "type": "string"
    },
    "forbidden_shortcuts": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "shortcut_id": {
            "minLength": 1,
            "type": "string"
          },
          "summary": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "shortcut_id",
          "summary"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "phases": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "allowed_next": {
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "type": "array"
          },
          "phase_id": {
            "minLength": 1,
            "type": "string"
          },
          "required_checks": {
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "type": "array"
          },
          "required_evidence": {
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "type": "array"
          },
          "summary": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "phase_id",
          "summary",
          "required_evidence",
          "required_checks",
          "allowed_next"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "run_record_required": {
      "description": "True only when SkillGuard owns the runtime execution route. Native-integrated and hybrid-extension contracts must bind target-owned routes/checks instead.",
      "type": "boolean"
    },
    "quality_floors": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "failure_effect": {
            "minLength": 1,
            "type": "string"
          },
          "floor_id": {
            "minLength": 1,
            "type": "string"
          },
          "required_checks": {
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "type": "array"
          },
          "summary": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "floor_id",
          "summary",
          "required_checks",
          "failure_effect"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "required_evidence": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "evidence_id": {
            "minLength": 1,
            "type": "string"
          },
          "kind": {
            "minLength": 1,
            "type": "string"
          },
          "phase_id": {
            "minLength": 1,
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "source": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "evidence_id",
          "phase_id",
          "kind",
          "source",
          "required"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "routes": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "activation_keywords": {
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "type": "array"
          },
          "do_not_use_when": {
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "type": "array"
          },
          "default_route": {
            "type": "boolean"
          },
          "phase_order": {
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "type": "array"
          },
          "route_id": {
            "minLength": 1,
            "type": "string"
          },
          "route_priority": {
            "minimum": 0,
            "type": "integer"
          },
          "route_source": {
            "enum": [
              "native_binding",
              "hybrid_extension",
              "skillguard_runtime"
            ],
            "type": "string"
          },
          "summary": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "route_id",
          "route_source",
          "summary",
          "activation_keywords",
          "do_not_use_when",
          "phase_order"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "schema_version": {
      "const": "skillguard.work_contract.v1",
      "type": "string"
    },
    "skill_specific_checks": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "check_id": {
            "minLength": 1,
            "type": "string"
          },
          "check_manifest_ids": {
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "type": "array"
          },
          "native_check_binding_ids": {
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "type": "array"
          },
          "obligation_ids": {
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "minItems": 1,
            "type": "array"
          },
          "required": {
            "type": "boolean"
          },
          "summary": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "check_id",
          "obligation_ids",
          "check_manifest_ids",
          "native_check_binding_ids",
          "required",
          "summary"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "skill_id": {
      "minLength": 1,
      "type": "string"
    },
    "source_requirements": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "category": {
            "minLength": 1,
            "type": "string"
          },
          "requirement_id": {
            "minLength": 1,
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "source_path": {
            "minLength": 1,
            "type": "string"
          },
          "summary": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "requirement_id",
          "category",
          "summary",
          "source_path",
          "required"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "skillguard_role": {
      "enum": [
        "native_contract_executor",
        "hybrid_contract_executor",
        "runtime_owner"
      ],
      "type": "string"
    },
    "stale_bindings": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "binding_id": {
            "minLength": 1,
            "type": "string"
          },
          "path": {
            "minLength": 1,
            "type": "string"
          },
          "stales": {
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "type": "array"
          }
        },
        "required": [
          "binding_id",
          "path",
          "stales"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "target_path": {
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "skill_id",
    "target_path",
    "contract_version",
    "contract_hash",
    "integration_mode",
    "native_route_owner",
    "native_route_bindings",
    "native_check_bindings",
    "phase_native_bindings",
    "source_requirements",
    "acceptance_obligations",
    "skill_specific_checks",
    "closure_blockers",
    "run_record_required",
    "not_parallel_route_proof",
    "cleanup_required",
    "skillguard_role",
    "may_define_parallel_execution_route",
    "may_define_skillguard_runtime_route",
    "integration_claim_boundary",
    "routes",
    "phases",
    "required_evidence",
    "quality_floors",
    "forbidden_shortcuts",
    "check_scripts",
    "closure_rules",
    "stale_bindings",
    "claim_boundary"
  ],
  "title": "SkillGuardWorkContract",
  "type": "object"
}
