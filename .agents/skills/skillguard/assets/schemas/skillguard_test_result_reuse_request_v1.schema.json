{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SkillGuard test result reuse request v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "skill_id", "guard_change", "previous_result", "current_identity"],
  "properties": {
    "schema_version": {"const": "skillguard.test_result_reuse_request.v1"},
    "skill_id": {"type": "string", "minLength": 1},
    "guard_change": {"type": "object"},
    "previous_result": {"$ref": "#/$defs/identity"},
    "current_identity": {"$ref": "#/$defs/identity"}
  },
  "$defs": {
    "hash": {"type": "string", "pattern": "^[A-F0-9]{64}$"},
    "identity": {
      "type": "object",
      "additionalProperties": true,
      "required": ["source_fingerprint", "contract_hash", "command_fingerprint", "environment_fingerprint", "coverage_fingerprint"],
      "properties": {
        "source_fingerprint": {"$ref": "#/$defs/hash"},
        "contract_hash": {"$ref": "#/$defs/hash"},
        "command_fingerprint": {"$ref": "#/$defs/hash"},
        "environment_fingerprint": {"$ref": "#/$defs/hash"},
        "coverage_fingerprint": {"$ref": "#/$defs/hash"}
      }
    }
  }
}
