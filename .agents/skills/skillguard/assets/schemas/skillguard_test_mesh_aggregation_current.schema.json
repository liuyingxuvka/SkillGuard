{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "skillguard_test_mesh_aggregation_current.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "maintenance_unit_id", "member_skill_id", "status", "mode", "execution_count", "findings"],
  "properties": {
    "schema_version": {"const": "skillguard.test_mesh_aggregation.current"},
    "maintenance_unit_id": {"type": "string", "minLength": 1},
    "member_skill_id": {"type": "string", "minLength": 1},
    "status": {"enum": ["passed", "blocked"]},
    "mode": {"const": "aggregation_only"},
    "execution_count": {"const": 0},
    "profile_id": {"type": "string"},
    "plan_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "full_admission_required": {"type": "boolean"},
    "selection_declaration_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "snapshot_identity_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "impact_graph_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "aggregation_id": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "aggregation_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "child_receipts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["execution_owner_id", "check_ids", "check_projections", "receipt_id", "receipt_hash", "receipt_ref"],
        "properties": {
          "execution_owner_id": {"type": "string", "minLength": 1},
          "check_ids": {"$ref": "#/$defs/checkIds"},
          "check_projections": {"$ref": "#/$defs/checkProjections"},
          "receipt_id": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
          "receipt_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
          "receipt_ref": {"$ref": "#/$defs/contentRef"}
        }
      }
    },
    "installation_verification_identity": {
      "oneOf": [
        {"type": "null"},
        {"$ref": "#/$defs/installationBinding"}
      ]
    },
    "typed_domain_bindings": {
      "type": "array",
      "maxItems": 1,
      "items": {"$ref": "#/$defs/globalPromptBinding"}
    },
    "external_projection_bindings_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "aggregation_ref": {"$ref": "#/$defs/contentRef"},
    "findings": {"type": "array", "items": {"type": "string"}},
    "claim_boundary": {"type": "string"}
  },
  "if": {"properties": {"status": {"const": "passed"}}},
  "then": {"required": ["profile_id", "plan_hash", "full_admission_required", "selection_declaration_hash", "snapshot_identity_hash", "impact_graph_hash", "aggregation_id", "aggregation_hash", "child_receipts", "installation_verification_identity", "typed_domain_bindings", "external_projection_bindings_hash", "claim_boundary"]},
  "$defs": {
    "hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "checkIds": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "checkProjections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["check_id", "semantic_check_id", "projection_declaration_hash"],
        "properties": {
          "check_id": {"type": "string", "minLength": 1},
          "semantic_check_id": {"type": "string", "minLength": 1},
          "projection_declaration_hash": {"$ref": "#/$defs/hash"}
        }
      }
    },
    "contentRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path_token", "relative_path", "content_hash", "media_type", "byte_count"],
      "properties": {
        "path_token": {"enum": ["owner_evidence_root"]},
        "relative_path": {"type": "string", "minLength": 1},
        "content_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "media_type": {"const": "application/json"},
        "byte_count": {"type": "integer", "minimum": 0}
      }
    },
    "portableLocator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path_token", "relative_path"],
      "properties": {
        "path_token": {"const": "codex_home"},
        "relative_path": {"type": "string", "minLength": 1}
      }
    },
    "globalPromptBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "evidence_domain", "owner_id", "registry_ref", "projection_ref", "prompt_ref", "registry_hash", "managed_prompt_block_hash", "prompt_projection_identity_hash", "content_consumer_projection_hash", "binding_hash"],
      "properties": {
        "schema_version": {"const": "skillguard.test_mesh_typed_domain_binding.current"},
        "evidence_domain": {"const": "global_prompt"},
        "owner_id": {"const": "skillguard-global-router"},
        "registry_ref": {"$ref": "#/$defs/portableLocator"},
        "projection_ref": {"$ref": "#/$defs/portableLocator"},
        "prompt_ref": {"$ref": "#/$defs/portableLocator"},
        "registry_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "managed_prompt_block_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "prompt_projection_identity_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "content_consumer_projection_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "binding_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
      }
    },
    "installationBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "evidence_domain", "owner_id", "installation_receipt_root_ref", "member_projection_hash", "content_consumer_projection_hash", "installed_smoke_result_hash", "installed_smoke_contract_hash", "owner_receipt_projection_hash", "binding_hash"],
      "properties": {
        "schema_version": {"const": "skillguard.test_mesh_typed_domain_binding.current"},
        "evidence_domain": {"const": "active_installation"},
        "owner_id": {"const": "skillguard-installation"},
        "installation_receipt_root_ref": {"$ref": "#/$defs/portableLocator"},
        "member_projection_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "content_consumer_projection_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "installed_smoke_result_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "installed_smoke_contract_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "owner_receipt_projection_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "binding_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
      }
    }
  }
}
