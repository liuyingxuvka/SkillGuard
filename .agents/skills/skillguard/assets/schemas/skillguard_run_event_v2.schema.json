{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skillguard.local/schemas/skillguard_run_event_v2.schema.json",
  "title": "SkillGuard Run Event V2",
  "type": "object",
  "required": ["schema_version", "event_id", "run_id", "sequence", "event_type", "created_at", "payload_hash"],
  "properties": {
    "schema_version": {"const": "skillguard.run_event.v2"},
    "event_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "sequence": {"type": "integer", "minimum": 1},
    "event_type": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "payload_hash": {"type": "string", "minLength": 1}
  },
  "additionalProperties": true
}
