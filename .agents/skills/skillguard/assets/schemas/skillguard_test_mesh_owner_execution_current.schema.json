{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "skillguard_test_mesh_owner_execution_current.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "artifact_type", "status", "mode", "profile_id", "plan_hash", "planned_execute_owner_ids", "planned_reuse_owner_ids", "verified_planned_reuse_owner_ids", "executed_owner_ids", "reused_after_freeze_owner_ids", "failed_owner_ids", "not_run_owner_ids", "execution_count", "owner_results", "findings", "claim_boundary"],
  "properties": {
    "schema_version": {"const": "skillguard.test_mesh_owner_execution.current"},
    "artifact_type": {"const": "skillguard_test_mesh_owner_execution"},
    "status": {"enum": ["passed", "failed", "blocked"]},
    "mode": {"const": "owner_execution_only"},
    "profile_id": {"type": "string"},
    "plan_hash": {"type": "string", "pattern": "^(|sha256:[0-9a-f]{64})$"},
    "planned_execute_owner_ids": {"$ref": "#/$defs/ownerIds"},
    "planned_reuse_owner_ids": {"$ref": "#/$defs/ownerIds"},
    "verified_planned_reuse_owner_ids": {"$ref": "#/$defs/ownerIds"},
    "executed_owner_ids": {"$ref": "#/$defs/ownerIds"},
    "reused_after_freeze_owner_ids": {"$ref": "#/$defs/ownerIds"},
    "failed_owner_ids": {"$ref": "#/$defs/ownerIds"},
    "not_run_owner_ids": {"$ref": "#/$defs/ownerIds"},
    "execution_count": {"type": "integer", "minimum": 0},
    "owner_results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["execution_owner_id", "primary_check_id", "check_ids", "check_projections", "step_id", "planned_disposition", "terminal_disposition", "process_started", "receipt_id", "receipt_hash", "receipt_ref", "finding"],
        "properties": {
          "execution_owner_id": {"type": "string", "minLength": 1},
          "primary_check_id": {"type": "string", "minLength": 1},
          "check_ids": {"$ref": "#/$defs/checkIds"},
          "check_projections": {"$ref": "#/$defs/checkProjections"},
          "step_id": {"type": "string", "minLength": 1},
          "planned_disposition": {"enum": ["execute_owner", "reuse_owner_receipt"]},
          "terminal_disposition": {"type": "string", "minLength": 1},
          "process_started": {"type": "boolean"},
          "receipt_id": {"type": "string", "pattern": "^(|sha256:[0-9a-f]{64})$"},
          "receipt_hash": {"type": "string", "pattern": "^(|sha256:[0-9a-f]{64})$"},
          "receipt_ref": {
            "oneOf": [
              {"type": "null"},
              {"$ref": "#/$defs/contentRef"}
            ]
          },
          "finding": {"type": "string"}
        }
      }
    },
    "findings": {"type": "array", "items": {"type": "string"}},
    "claim_boundary": {"type": "string", "minLength": 1}
  },
  "$defs": {
    "hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "checkIds": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "checkProjections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["check_id", "semantic_check_id", "projection_declaration_hash"],
        "properties": {
          "check_id": {"type": "string", "minLength": 1},
          "semantic_check_id": {"type": "string", "minLength": 1},
          "projection_declaration_hash": {"$ref": "#/$defs/hash"}
        }
      }
    },
    "ownerIds": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "contentRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path_token", "relative_path", "content_hash", "media_type", "byte_count"],
      "properties": {
        "path_token": {"const": "owner_evidence_root"},
        "relative_path": {"type": "string", "minLength": 1},
        "content_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "media_type": {"const": "application/json"},
        "byte_count": {"type": "integer", "minimum": 0}
      }
    }
  }
}
