{
  "title": "SkillGuard Check Report",
  "description": "Record-family schema for deterministic and judgment-supported SkillGuard check reports. It records evidence, checks, failures, blockers, skipped checks, residual risk, and claim boundary. This schema defines record shape only; it does not claim runtime checker execution, fixture coverage, CLI checks, tests, suite automation, package publication, or code-contract validation.",
  "type": "object",
  "required": [
    "schema_version",
    "target_path",
    "target_type",
    "status",
    "checker_version",
    "checks",
    "evidence",
    "failures",
    "blockers",
    "skipped_checks",
    "residual_risk",
    "claim_boundary"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "skillguard.check_report.v1"
    },
    "target_path": {
      "type": "string"
    },
    "target_type": {
      "type": "string",
      "enum": [
        "skill",
        "suite",
        "repository",
        "reference",
        "schema",
        "fixture",
        "workflow"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "block",
        "checked",
        "needs-review",
        "stale"
      ]
    },
    "checker_version": {
      "type": "string"
    },
    "compatibility": {
      "type": "object",
      "required": [
        "checker_version",
        "fixture_version"
      ],
      "properties": {
        "checker_version": {
          "type": "string"
        },
        "fixture_version": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "check_id",
          "name",
          "required",
          "status"
        ],
        "properties": {
          "check_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "fail",
              "block",
              "skipped",
              "not_checked"
            ]
          },
          "evidence_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "summary": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "evidence_id",
          "kind",
          "fresh",
          "summary"
        ],
        "properties": {
          "evidence_id": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "fresh": {
            "type": "boolean"
          },
          "summary": {
            "type": "string"
          },
          "source_path": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "failures": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "skipped_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "check_id",
          "reason",
          "required",
          "status_impact"
        ],
        "properties": {
          "check_id": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "status_impact": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "residual_risk": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "claim_boundary": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
