{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skillguard.local/schemas/skillguard_contract_source_v2.schema.json",
  "title": "SkillGuard Contract Binding Source V2",
  "type": "object",
  "required": ["schema_version", "skill_id", "model_id", "model_path", "confirmed", "step_bindings", "checks", "artifacts", "closure_profiles", "claim_boundary"],
  "properties": {
    "schema_version": {"const": "skillguard.contract_source.v2"},
    "skill_id": {"type": "string", "minLength": 1},
    "model_id": {"type": "string", "minLength": 1},
    "model_path": {"type": "string", "minLength": 1},
    "confirmed": {"const": true},
    "step_bindings": {"type": "array", "items": {"type": "object", "required": ["step_id", "action", "check_ids", "output_artifact_ids"]}},
    "checks": {"type": "array", "items": {"type": "object", "required": ["check_id", "kind", "evidence_class", "covers_obligation_ids"]}},
    "artifacts": {"type": "array", "items": {"type": "object", "required": ["artifact_id", "kind", "producer_step_id", "validators"]}},
    "closure_profiles": {"type": "array", "minItems": 4, "items": {"type": "object", "required": ["profile_id", "required_obligation_ids"]}},
    "judgment_rubrics": {"type": "array", "items": {"type": "object"}},
    "claim_boundary": {"type": "string", "minLength": 1}
  },
  "additionalProperties": true
}
