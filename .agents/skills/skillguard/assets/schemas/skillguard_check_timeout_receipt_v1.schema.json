{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skillguard.local/schemas/skillguard_check_timeout_receipt_v1.schema.json",
  "title": "SkillGuard Manifest Check Timeout Receipt V1",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_type",
    "receipt_kind",
    "policy_version",
    "receipt_id",
    "receipt_hash",
    "status",
    "owner_ref",
    "step_id",
    "check_id",
    "command_token",
    "command_fingerprint",
    "started_at",
    "deadline_at",
    "finished_at",
    "elapsed_ms",
    "timeout_ms",
    "stdout_content_hash",
    "stderr_content_hash",
    "stdout_total_bytes",
    "stderr_total_bytes",
    "partial_output_content_hash",
    "reason",
    "resume_action",
    "retry_action",
    "terminal_kind",
    "termination_scope",
    "termination_attempted",
    "termination_succeeded",
    "claim_boundary"
  ],
  "properties": {
    "schema_version": {"const": "skillguard.check_timeout_receipt.v1"},
    "artifact_type": {"const": "skillguard_check_timeout_receipt"},
    "receipt_kind": {"const": "execution_timeout"},
    "policy_version": {"const": "skillguard.timeout_policy.v1"},
    "receipt_id": {"type": "string", "pattern": "^timeout-[0-9a-f]{24}$"},
    "receipt_hash": {"$ref": "#/$defs/hash"},
    "status": {"const": "timed_out"},
    "owner_ref": {"$ref": "#/$defs/owner"},
    "step_id": {"type": "string", "minLength": 1},
    "check_id": {"type": "string", "minLength": 1},
    "command_token": {"type": "string", "minLength": 1, "pattern": "^[^/\\\\]+$"},
    "command_fingerprint": {"$ref": "#/$defs/hash"},
    "started_at": {"$ref": "#/$defs/timestamp"},
    "deadline_at": {"$ref": "#/$defs/timestamp"},
    "finished_at": {"$ref": "#/$defs/timestamp"},
    "elapsed_ms": {"type": "integer", "minimum": 0},
    "timeout_ms": {"type": "integer", "exclusiveMinimum": 0},
    "stdout_content_hash": {"$ref": "#/$defs/contentHash"},
    "stderr_content_hash": {"$ref": "#/$defs/contentHash"},
    "stdout_total_bytes": {"type": "integer", "minimum": 0},
    "stderr_total_bytes": {"type": "integer", "minimum": 0},
    "stdout_captured_bytes": {"type": "integer", "minimum": 0},
    "stderr_captured_bytes": {"type": "integer", "minimum": 0},
    "output_truncated": {"type": "boolean"},
    "partial_output_content_hash": {"$ref": "#/$defs/contentHash"},
    "reason": {"const": "declared_timeout_elapsed"},
    "resume_action": {"type": "string", "minLength": 1},
    "retry_action": {"type": "string", "minLength": 1},
    "terminal_kind": {"const": "timeout"},
    "termination_scope": {"enum": ["process_tree"]},
    "termination_attempted": {"const": true},
    "termination_succeeded": {"type": "boolean"},
    "termination_method": {"type": "string"},
    "termination_error_kind": {"type": "string"},
    "diagnostic_ref": {"$ref": "#/$defs/pathLocator"},
    "claim_boundary": {"type": "string", "minLength": 1}
  },
  "$defs": {
    "hash": {"type": "string", "pattern": "^[0-9A-F]{64}$"},
    "contentHash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "timestamp": {"type": "string", "minLength": 20},
    "pathLocator": {
      "type": "object",
      "required": ["path_token", "relative_path"],
      "properties": {
        "path_token": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
        "relative_path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/)(?![A-Za-z]:)(?!\\\\)(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).+$"
        }
      },
      "additionalProperties": false
    },
    "owner": {
      "type": "object",
      "required": [
        "owner_type",
        "owner_hash",
        "run_id",
        "contract_hash",
        "check_manifest_hash",
        "check_declarations_hash",
        "declared_check_hash",
        "execution_environment_fingerprint"
      ],
      "properties": {
        "owner_type": {"const": "manifest_bound_check"},
        "owner_hash": {"$ref": "#/$defs/hash"},
        "run_id": {"type": "string", "minLength": 1},
        "contract_hash": {"$ref": "#/$defs/hash"},
        "check_manifest_hash": {"$ref": "#/$defs/hash"},
        "check_declarations_hash": {"$ref": "#/$defs/hash"},
        "declared_check_hash": {"$ref": "#/$defs/hash"},
        "execution_environment_fingerprint": {"$ref": "#/$defs/hash"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
