{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/liuyingxuvka/SkillGuard/schemas/skillguard_portfolio_impact_receipt_v1.schema.json",
  "title": "SkillGuard portfolio impact receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "change_id", "change_hash", "impact_graph_hash", "changed_component_ids", "status", "invalidated_target_ids", "target_statuses", "guard_before_hash", "guard_after_hash", "registry_ref", "registry_hash", "claim_boundary", "receipt_id", "receipt_hash"],
  "properties": {
    "schema_version": {"const": "skillguard.portfolio_impact_receipt.v1"},
    "change_id": {"type": "string", "minLength": 1},
    "change_hash": {"$ref": "#/$defs/hash"},
    "impact_graph_hash": {"$ref": "#/$defs/wire_hash"},
    "changed_component_ids": {"$ref": "#/$defs/idList"},
    "status": {"const": "revalidation_required"},
    "affected_target_ids": {"$ref": "#/$defs/idListMaybeEmpty"},
    "invalidated_target_ids": {"$ref": "#/$defs/idList"},
    "required_target_ids": {"$ref": "#/$defs/idListMaybeEmpty"},
    "required_member_ids_by_suite": {"$ref": "#/$defs/memberIdsBySuite"},
    "required_impact_ids": {"$ref": "#/$defs/idList"},
    "invalidated_member_ids": {"$ref": "#/$defs/idListMaybeEmpty"},
    "target_statuses": {"type": "object", "minProperties": 1, "additionalProperties": {"type": "object"}},
    "member_revalidation_statuses": {"$ref": "#/$defs/memberStatusesBySuite"},
    "status_transitions": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/statusTransition"}
    },
    "registry_transaction_id": {"type": "string", "minLength": 1},
    "guard_before_hash": {"$ref": "#/$defs/hash"},
    "guard_after_hash": {"$ref": "#/$defs/hash"},
    "registry_ref": {"type": "object"},
    "registry_hash": {"$ref": "#/$defs/hash"},
    "claim_boundary": {"type": "string", "minLength": 1},
    "receipt_id": {"type": "string", "pattern": "^portfolio-impact-[a-f0-9]{24}$"},
    "receipt_hash": {"$ref": "#/$defs/hash"}
  },
  "$defs": {
    "hash": {"type": "string", "pattern": "^[A-F0-9]{64}$"},
    "wire_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "idList": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "idListMaybeEmpty": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "memberIdsBySuite": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": {"type": "string", "minLength": 1}
      }
    },
    "memberStatus": {
      "type": "object",
      "additionalProperties": false,
      "required": ["graduation_status", "pending_guard_change_id"],
      "properties": {
        "graduation_status": {"const": "revalidation_required"},
        "pending_guard_change_id": {"type": "string", "minLength": 1}
      }
    },
    "memberStatusesBySuite": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": {"$ref": "#/$defs/memberStatus"}
      }
    },
    "statusTransition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope_kind", "target_id", "member_id", "before_status", "after_status"],
      "properties": {
        "scope_kind": {"enum": ["portfolio_target", "suite_member"]},
        "target_id": {"type": "string", "minLength": 1},
        "member_id": {"type": "string"},
        "before_status": {"type": "string", "minLength": 1},
        "after_status": {"const": "revalidation_required"}
      }
    }
  }
}
