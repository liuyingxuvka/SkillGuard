{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "skillguard_test_mesh_execution_plan_current.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "artifact_type", "maintenance_unit_id", "member_skill_id", "status", "mode", "profile_id", "execution_count", "selected_owner_ids", "changed_component_ids", "will_reuse_owner_ids", "will_execute_owner_ids", "will_aggregate_only", "required_install_component_ids", "required_router_refresh", "required_portfolio_target_ids", "full_required_reason_codes", "owner_plans", "findings", "claim_boundary"],
  "properties": {
    "schema_version": {"const": "skillguard.test_mesh_execution_plan.current"},
    "artifact_type": {"const": "skillguard_test_mesh_execution_plan"},
    "maintenance_unit_id": {"type": "string", "minLength": 1},
    "member_skill_id": {"type": "string", "minLength": 1},
    "status": {"enum": ["passed", "blocked"]},
    "mode": {"const": "plan_only"},
    "profile_id": {"type": "string"},
    "full_admission_required": {"type": "boolean"},
    "full_admission_reason": {"type": "string"},
    "execution_count": {"const": 0},
    "selected_owner_ids": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "changed_component_ids": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "will_reuse_owner_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "will_execute_owner_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "will_aggregate_only": {"type": "boolean"},
    "required_install_component_ids": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "required_router_refresh": {"type": "boolean"},
    "required_portfolio_target_ids": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "full_required_reason_codes": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "owner_plans": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["execution_owner_id", "primary_check_id", "check_ids", "check_projections", "owner_declaration_hash", "owner_input_projection_hash", "input_components", "depends_on_owner_ids", "evidence_domain_id", "toolchain_fingerprint", "execution_environment_fingerprint", "decision", "reason", "reusable_receipt"],
        "properties": {
          "execution_owner_id": {"type": "string", "minLength": 1},
          "primary_check_id": {"type": "string", "minLength": 1},
          "check_ids": {"$ref": "#/$defs/checkIds"},
          "check_projections": {"$ref": "#/$defs/checkProjections"},
          "owner_declaration_hash": {"$ref": "#/$defs/hash"},
          "owner_input_projection_hash": {"$ref": "#/$defs/hash"},
          "input_components": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["component_id", "component_hash"],
              "properties": {
                "component_id": {"type": "string", "minLength": 1},
                "component_hash": {"$ref": "#/$defs/hash"}
              }
            },
            "uniqueItems": true
          },
          "depends_on_owner_ids": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
          "evidence_domain_id": {"type": "string"},
          "toolchain_fingerprint": {"$ref": "#/$defs/hash"},
          "execution_environment_fingerprint": {"$ref": "#/$defs/hash"},
          "decision": {"enum": ["reuse_owner_receipt", "execute_owner"]},
          "reason": {"type": "string", "minLength": 1},
          "reusable_receipt": {
            "oneOf": [
              {"type": "null"},
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["receipt_id", "receipt_hash", "receipt_ref"],
                "properties": {
                  "receipt_id": {"$ref": "#/$defs/hash"},
                  "receipt_hash": {"$ref": "#/$defs/hash"},
                  "receipt_ref": {"$ref": "#/$defs/contentRef"}
                }
              }
            ]
          }
        }
      }
    },
    "findings": {"type": "array", "items": {"type": "string"}},
    "plan_hash": {"$ref": "#/$defs/hash"},
    "selection_declaration_hash": {"$ref": "#/$defs/hash"},
    "snapshot_identity_hash": {"$ref": "#/$defs/hash"},
    "source_identity_hash": {"$ref": "#/$defs/hash"},
    "toolchain_identity_hash": {"$ref": "#/$defs/hash"},
    "impact_graph_hash": {"$ref": "#/$defs/hash"},
    "claim_boundary": {"type": "string", "minLength": 1}
  },
  "if": {"properties": {"status": {"const": "passed"}}},
  "then": {"required": ["full_admission_required", "full_admission_reason", "selection_declaration_hash", "snapshot_identity_hash", "source_identity_hash", "toolchain_identity_hash", "impact_graph_hash", "plan_hash"]},
  "$defs": {
    "hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "checkIds": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "checkProjections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["check_id", "semantic_check_id", "projection_declaration_hash"],
        "properties": {
          "check_id": {"type": "string", "minLength": 1},
          "semantic_check_id": {"type": "string", "minLength": 1},
          "projection_declaration_hash": {"$ref": "#/$defs/hash"}
        }
      }
    },
    "contentRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path_token", "relative_path", "content_hash", "media_type", "byte_count"],
      "properties": {
        "path_token": {"const": "owner_evidence_root"},
        "relative_path": {"type": "string", "minLength": 1},
        "content_hash": {"$ref": "#/$defs/hash"},
        "media_type": {"const": "application/json"},
        "byte_count": {"type": "integer", "minimum": 0}
      }
    }
  }
}
