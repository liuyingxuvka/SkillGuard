{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SkillGuard portfolio graduation evidence v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "skill_id", "source_fingerprint", "contract_hash", "guard_runtime", "representative_jobs", "full_run_receipt", "failure_classification"],
  "properties": {
    "schema_version": {"const": "skillguard.portfolio_graduation_evidence.v1"},
    "skill_id": {"type": "string", "minLength": 1},
    "version": {"type": "string"},
    "source_fingerprint": {"$ref": "#/$defs/hash"},
    "contract_hash": {"$ref": "#/$defs/hash"},
    "guard_runtime": {"$ref": "#/$defs/guard"},
    "representative_jobs": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/job"}},
    "full_run_receipt": {"$ref": "#/$defs/full_receipt"},
    "failure_classification": {
      "type": ["string", "null"],
      "enum": [null, "target_implementation_gap", "target_contract_binding_gap", "skillguard_model_miss", "skillguard_runtime_or_validator_gap", "environment_or_external_blocker"]
    }
  },
  "$defs": {
    "hash": {"type": "string", "pattern": "^[A-F0-9]{64}$"},
    "guard": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtime_id", "file_count", "source_hash"],
      "properties": {
        "runtime_id": {"const": "skillguard-v2"},
        "file_count": {"type": "integer", "minimum": 1},
        "source_hash": {"$ref": "#/$defs/hash"}
      }
    },
    "job": {
      "type": "object",
      "additionalProperties": false,
      "required": ["job_id", "covered_capability_ids", "evidence_refs"],
      "properties": {
        "job_id": {"type": "string", "minLength": 1},
        "covered_capability_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "evidence_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    },
    "full_receipt": {
      "type": "object",
      "additionalProperties": true,
      "required": ["receipt_id", "status", "guard_runtime", "source_fingerprint", "contract_hash", "command_fingerprint", "environment_fingerprint", "coverage_fingerprint", "result_hash", "completed_at"],
      "properties": {
        "receipt_id": {"type": "string", "minLength": 1},
        "status": {"const": "current"},
        "guard_runtime": {"$ref": "#/$defs/guard"},
        "source_fingerprint": {"$ref": "#/$defs/hash"},
        "contract_hash": {"$ref": "#/$defs/hash"},
        "command_fingerprint": {"$ref": "#/$defs/hash"},
        "environment_fingerprint": {"$ref": "#/$defs/hash"},
        "coverage_fingerprint": {"$ref": "#/$defs/hash"},
        "result_hash": {"$ref": "#/$defs/hash"},
        "completed_at": {"type": "string", "minLength": 1}
      }
    }
  }
}
