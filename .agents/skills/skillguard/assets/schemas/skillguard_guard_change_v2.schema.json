{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/liuyingxuvka/SkillGuard/schemas/skillguard_guard_change_v2.schema.json",
  "title": "SkillGuard transactional Guard change v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "change_id",
    "guard_before",
    "guard_after",
    "affected_feature_tags",
    "impact_graph_hash",
    "changed_component_ids",
    "reason",
    "transaction_id",
    "expected_registry_revision",
    "base_registry_hash"
  ],
  "properties": {
    "schema_version": {"const": "skillguard.guard_change.v2"},
    "change_id": {"type": "string", "minLength": 1},
    "guard_before": {"$ref": "#/$defs/guard"},
    "guard_after": {"$ref": "#/$defs/guard"},
    "affected_feature_tags": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "impact_graph_hash": {"$ref": "#/$defs/wire_hash"},
    "changed_component_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "reason": {"type": "string", "minLength": 1},
    "transaction_id": {"type": "string", "minLength": 1},
    "expected_registry_revision": {"type": "integer", "minimum": 1},
    "base_registry_hash": {"$ref": "#/$defs/hash"}
  },
  "$defs": {
    "hash": {"type": "string", "pattern": "^[A-F0-9]{64}$"},
    "wire_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "guard": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtime_id", "file_count", "source_hash", "portfolio_projection_hash"],
      "properties": {
        "runtime_id": {"const": "skillguard-v2"},
        "file_count": {"type": "integer", "minimum": 1},
        "source_hash": {"$ref": "#/$defs/hash"},
        "portfolio_projection_hash": {"$ref": "#/$defs/wire_hash"}
      }
    }
  }
}
