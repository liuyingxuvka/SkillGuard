{
  "schema_version": "skillguard.suite_contract.v1",
  "suite_name": "{{suite_name}}",
  "purpose": "{{suite_purpose}}",
  "target_path": "{{target_path}}",
  "status": "draft",
  "included_skills": [
    {
      "name": "{{skill_name}}",
      "path": "{{skill_path}}",
      "role": "{{skill_role}}",
      "status": "draft",
      "evidence_source": "{{evidence_source}}",
      "owner": "{{maintenance_owner}}"
    }
  ],
  "routing": [
    {
      "use_case": "{{use_case}}",
      "skill": "{{target_skill}}",
      "conflict_resolution": "{{conflict_resolution_rule}}"
    }
  ],
  "dependencies": [
    {
      "name": "{{dependency_name}}",
      "dependency_type": "skill",
      "required": true,
      "status": "{{dependency_status}}"
    }
  ],
  "shared_evidence_rules": [
    "{{shared_evidence_rule}}"
  ],
  "current_identity": {
    "suite_version": "{{suite_version}}",
    "checker_version": "{{checker_version}}",
    "current_notes": [
      "{{current_identity_note}}"
    ]
  },
  "validation_layers": [
    "{{validation_layer}}"
  ],
  "maintenance_ownership": [
    "{{maintenance_owner}} refreshes this suite contract when member responsibilities, routing, dependencies, validation layers, or evidence rules change."
  ],
  "evidence": [],
  "blockers": [],
  "skipped_checks": [],
  "residual_risk": [
    "{{residual_risk_statement}}"
  ],
  "claim_boundary": "{{claim_boundary_statement}} This template does not prove runtime checker execution, fixture coverage, CLI checks, tests, suite automation, package publication, or code-contract validation without separate current evidence."
}
