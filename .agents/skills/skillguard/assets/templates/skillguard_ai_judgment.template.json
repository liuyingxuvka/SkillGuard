  "input_evidence": [
    {
      "evidence_id": "{{evidence_id}}",
      "summary": "{{evidence_summary}}",
      "freshness": "{{freshness_statement}}"
    }
  ],
  "findings": [
    {
      "finding_id": "{{finding_id}}",
      "severity": "{{severity}}",
      "claim": "{{finding_claim}}",
      "supporting_evidence": [
