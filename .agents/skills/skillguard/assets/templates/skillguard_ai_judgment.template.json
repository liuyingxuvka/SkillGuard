      ],
      "limits": [
        "{{finding_limit}}"
      ]
    }
  ],
  "confidence": {
    "level": "{{confidence_level}}",
    "rationale": "{{confidence_rationale}}"
  },
  "uncertainty": [
    {
      "question": "{{open_question}}",
      "impact": "{{uncertainty_impact}}",
      "resolution_path": "{{resolution_path}}"
    }
  ],
  "human_review": {
    "required": true,
    "reason": "{{human_review_reason}}"
  },
  "evidence": [],
  "failures": [],
  "blockers": [],
  "skipped_checks": [],
  "residual_risk": [
    "{{residual_risk_statement}}"
  ],
  "claim_boundary": "{{claim_boundary_statement}} This template does not prove runtime checker execution, fixture coverage, CLI checks, tests, suite automation, package publication, or code-contract validation without separate current evidence."
