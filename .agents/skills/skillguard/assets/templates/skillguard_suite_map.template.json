{
  "schema_version": "skillguard.suite_map.v1",
  "suite_name": "{{suite_name}}",
  "target_path": "{{target_path}}",
  "status": "draft",
  "included_skills": [
    {
      "name": "{{skill_name}}",
      "path": "{{skill_path}}",
      "role": "{{skill_role}}",
      "status": "draft",
      "evidence_location": "{{evidence_location}}",
      "required": true,
      "owner": "{{maintenance_owner}}"
    }
  ],
  "relationships": [
    {
      "from_skill": "{{source_skill}}",
      "to_skill": "{{target_skill}}",
      "relationship_type": "prerequisite",
      "notes": "{{relationship_notes}}"
    }
  ],
  "routing_hints": [
    {
      "task_shape": "{{task_shape}}",
      "preferred_skill": "{{preferred_skill}}",
      "non_use_boundary": "{{non_use_boundary}}",
      "conflict_rule": "{{conflict_rule}}"
    }
  ],
  "evidence_expectations": [
    "{{evidence_expectation}}"
  ],
  "maintenance_ownership": [
    "{{maintenance_owner}} refreshes this suite map when member skills, routing hints, evidence expectations, or closure boundaries change."
  ],
  "compatibility": {
    "version_boundary": "{{version_boundary}}",
    "known_incompatibilities": [
      "{{known_incompatibility}}"
    ]
  },
  "evidence": [],
  "blockers": [],
  "residual_risk": [
    "{{residual_risk_statement}}"
  ],
  "claim_boundary": "{{claim_boundary_statement}} This template does not prove runtime checker execution, fixture coverage, CLI checks, tests, suite automation, package publication, or code-contract validation without separate current evidence."
}
